generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model users {
  id                         BigInt    @id @default(autoincrement())
  username                   String?   @db.VarChar(100)
  password                   String?   @db.VarChar(100)
  employee                   BigInt?
  last_login                 DateTime? @db.DateTime(0)
  last_update                DateTime? @db.DateTime(0)
  created                    DateTime? @db.DateTime(0)
  wrong_password_count       Int?      @default(0)
  last_wrong_attempt_at      DateTime? @db.DateTime(0)
  last_password_requested_at DateTime? @db.DateTime(0)
  employeeId                 BigInt?
  posted_by                  BigInt?
  status                     String    @default("1") @db.Char(1)
}

model employee {
  id                  BigInt    @id @default(autoincrement())
  firstName           String    @default("") @db.VarChar(100)
