  approvalStatus      String    @default("PENDING") @db.VarChar(20)
  branchId            BigInt?
  city                String?   @db.VarChar(100)
  confirmationDate    DateTime? @db.Date
  country             String?   @db.VarChar(100)
  createdAt           DateTime  @default(now())
  dateOfBirth         DateTime? @db.Date
  departmentId        BigInt?
  employee_id         String?   @unique @db.VarChar(20)
  employmentStatusId  String?   @db.VarChar(36)
  genderId            String?   @db.VarChar(36)
  hireDate            DateTime? @db.Date
  jobTitleId          String?   @db.VarChar(36)
  lifecycleStatus     String    @default("PENDING") @db.VarChar(20)
  middleName          String?   @db.VarChar(100)
  mobilePhone         String?   @db.VarChar(30)
  nationalityId       String?   @db.VarChar(36)
  outletId            BigInt?
  religionId          String?   @db.VarChar(36)
  supervisorId        BigInt?
  titleId             String?   @db.VarChar(36)
  unitId              BigInt?
  updatedAt           DateTime  @default(now()) @updatedAt
  bankAccount         String?   @db.VarChar(50)
  driverLicenseExp    DateTime? @db.Date
  driverLicenseNum    String?   @db.VarChar(30)
  nationalIdExpiry    DateTime? @db.Date
  nationalIdNumber    String?   @db.VarChar(50)
  passportExpiry      DateTime? @db.Date
  passportNumber      String?   @db.VarChar(30)
  approved_by         BigInt?
  approved_date       DateTime? @db.Date
  father_name         String?   @db.VarChar(50)
  fit_and_proper      String?   @db.VarChar(150)
  marital_status      String?   @db.VarChar(20)
  medicalClearance    String?   @db.VarChar(150)
  mother_name         String?   @db.VarChar(50)
  notcheId            BigInt?
  nxt_kin_address     String?   @db.VarChar(255)
  nxt_kin_email       String?   @db.VarChar(100)
  nxt_kin_fname       String?   @db.VarChar(100)
  nxt_kin_phone       String?   @db.VarChar(20)
  paygradeId          BigInt?
  personal_email      String?   @unique @db.VarChar(100)
  place_of_birth      String?   @db.VarChar(50)
  policeClearance     String?   @db.VarChar(150)
  posted_by           BigInt?
  profile_imagebase64 String?   @db.LongText
  retirement_date     DateTime? @db.Date
  spouse_name         String?   @db.VarChar(100)
  ssn_num             String?   @db.VarChar(20)
  staff_level         String?   @db.VarChar(36)
  staff_role          String?   @db.VarChar(36)
  termination_date    DateTime? @db.Date
  work_email          String?   @unique @db.VarChar(100)
  sync_status         String?   @db.VarChar(20)
  sync_error          String?   @db.VarChar(500)
}

model refresh_tokens {
  id         BigInt   @id @default(autoincrement())
  user_id    BigInt
  token      String   @db.Text
  expires_at DateTime
  revoked    Boolean  @default(false)
  created_at DateTime @default(now())
}

model permissions {
  id                    BigInt                  @id @default(autoincrement())
  created_at            DateTime                @default(now())
  guard_name            String                  @db.VarChar(255)
  name                  String                  @db.VarChar(255)
  updated_at            DateTime                @updatedAt
  model_has_permissions model_has_permissions[]
  role_has_permissions  role_has_permissions[]

  @@unique([name, guard_name], map: "permissions_name_guard_name_unique")
}

model roles {
  id                   BigInt                 @id @default(autoincrement())
  name                 String                 @db.VarChar(255)
  guard_name           String                 @db.VarChar(255)
  description          String?                @db.VarChar(255)
  is_system            Boolean                @default(false)
  status               String                 @default("1") @db.Char(1)
  created_at           DateTime               @default(now())
  updated_at           DateTime               @updatedAt
  model_has_roles      model_has_roles[]
  role_has_permissions role_has_permissions[]

  @@unique([name, guard_name], map: "roles_name_guard_name_unique")
}

model role_has_permissions {
  permission_id BigInt
  role_id       BigInt
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "role_has_permissions_permission_id_foreign")
  roles         roles       @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "role_has_permissions_role_id_foreign")

  @@id([permission_id, role_id])
  @@index([role_id], map: "role_has_permissions_role_id_fk")
}

model model_has_permissions {
  permission_id BigInt
  model_type    String      @db.VarChar(255)
  model_id      String
  permissions   permissions @relation(fields: [permission_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "model_has_permissions_permission_id_foreign")

  @@id([permission_id, model_id, model_type])
  @@index([model_id, model_type], map: "model_has_permissions_model_id_model_type_index")
}

model model_has_roles {
  role_id    BigInt
  model_type String @db.VarChar(255)
  model_id   String
  roles      roles  @relation(fields: [role_id], references: [id], onDelete: Cascade, onUpdate: Restrict, map: "model_has_roles_role_id_foreign")

  @@id([role_id, model_id, model_type])
  @@index([model_id, model_type], map: "model_has_roles_model_id_model_type_index")
}

